cove_reload() {
    # Serialize reloads with an atomic mkdir lock. The dashboard fires reload
    # in the background after every site add/delete, so rapid actions can spawn
    # many concurrent `cove reload` processes. Two concurrent `frankenphp reload`
    # calls reliably deadlock Caddy's admin server (10s shutdown timeout in
    # caddy-process.log), which wedges further reloads AND blocks HTTP requests
    # routed through FrankenPHP.
    #
    # Strategy: first caller holds the lock and does the work. Subsequent callers
    # touch a "pending" marker and exit immediately. When the holder finishes, it
    # re-runs once if the marker is set, so the final state always converges on
    # the latest on-disk Sites listing.
    local lock_dir="$COVE_DIR/.reload.lock.d"
    local pending="$COVE_DIR/.reload.pending"

    if ! mkdir "$lock_dir" 2>/dev/null; then
        # Another reload is in flight — unless it died and left a stale lock.
        local holder_pid
        holder_pid=$(cat "$lock_dir/pid" 2>/dev/null)
        if [ -n "$holder_pid" ] && kill -0 "$holder_pid" 2>/dev/null; then
            touch "$pending"
            return 0
        fi
        # Holder PID is dead — reclaim.
        rm -rf "$lock_dir"
        if ! mkdir "$lock_dir" 2>/dev/null; then
            # Lost the race to another reclaimer; defer to them.
            touch "$pending"
            return 0
        fi
    fi

    echo $$ > "$lock_dir/pid"
    trap 'rm -rf "$lock_dir"; trap - EXIT INT TERM' EXIT INT TERM

    while :; do
        rm -f "$pending"
        create_gui_file
        regenerate_caddyfile
        update_etc_hosts
        [ -f "$pending" ] || break
    done
}
